{
  "name": "web",
  "version": "1.5.7",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,agent \"next dev\" \"node print-agent/server.js\"",
    "dev:web": "next dev",
    "dev:agent": "node print-agent/server.js",
    "build": "next build",
    "start": "next start",
    "start:local": "concurrently -n next,agent \"next start\" \"node print-agent/server.js\"",
    "lint": "npm run lint:app",
    "lint:app": "eslint src eslint.config.mjs next.config.ts",
    "lint:repo": "eslint .",
    "lint:scripts": "eslint scripts execution print-agent prisma debug_sku.ts",
    "typecheck": "tsc --pretty false --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "check:diff": "node scripts/check_quality_diff.mjs",
    "test:print-layout": "tsx scripts/check-print-layout.ts && node --test print-agent/printService.test.js",
    "build:print-agent-installer": "node scripts/build-print-agent-installer.js",
    "postinstall": "prisma generate",
    "release": "npm version patch && git push origin Oswaldo_cambios --follow-tags"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@sparticuz/chromium": "^148.0.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "exceljs": "^4.4.0",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "pg-pool": "^3.13.0",
    "postgres": "^3.4.8",
    "puppeteer": "^25.1.0",
    "puppeteer-core": "^25.1.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shadcn": "^4.8.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
