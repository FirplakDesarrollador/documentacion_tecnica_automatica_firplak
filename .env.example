# Configuración de variables de entorno para el proyecto
# Copia este archivo a .env y rellena con tus propios valores

# Conexión a la base de datos (SQLite por defecto para desarrollo)
DATABASE_URL="file:./dev.db"

# Token de acceso a la API de GitHub (Personal Access Token)
# Necesario para operaciones de repositorio y lectura de archivos
GITHUB_TOKEN="tu_ghp_token_aqui"
GITHUB_USER="@tu_username"

# API Key de Google Gemini (Para el asistente Antigravity)
GEMINI_API_KEY="AIzaSy..."

# Token de acceso de Supabase (Opcional si se usa la integración de Supabase)
SUPABASE_ACCESS_TOKEN="sbp_..."
