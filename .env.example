# --- BASE DE DATOS LOCAL (Prisma/SQLite) ---
DATABASE_URL="file:./dev.db"

# --- MASS IMPORT (V6) ---
# Configurable from the app at /rules (stored in public.app_settings).
# No .env flags are used for this module.

# --- NAMING RECOMPUTE ---
# Shared secret required by POST /api/naming/process-stale.
# Configure the real value locally in .env and in Vercel production env vars.
NAMING_RECOMPUTE_SECRET="generate_a_secure_random_value"

# --- SAP BUSINESS ONE SERVICE LAYER ---
# Keep SAP_PASSWORD quoted if it contains #, spaces, or other shell-sensitive chars.
SAP_COMPANY_DB="your_company_db"
SAP_USERNAME="your_sap_user"
SAP_PASSWORD="change_me"
SAP_API_URL="https://sap-host-or-ip:50000/b1s/v1/Login"
# Firplak's Service Layer currently uses a certificate that may not validate by IP.
SAP_REJECT_UNAUTHORIZED="false"
# Leave disabled until create/update flows are explicitly approved.
SAP_ENABLE_WRITES="false"
